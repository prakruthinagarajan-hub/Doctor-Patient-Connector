def validate_aadhar(a):
    return a.isdigit() and len(a) == 12


def patient_signup():
    name = p_name.get()
    age = p_age.get()
    gender = p_gender.get()
    area = p_area.get()
    aadhar = p_aadhar.get()
    password = p_password.get()

    if not validate_aadhar(aadhar):
        messagebox.showerror("Error", "Invalid Aadhaar")
        return
    
    try:
        cursor.execute(
            "INSERT INTO patients(name,age,gender,area,aadhar,password) VALUES(%s,%s,%s,%s,%s,%s)",
            (name, age, gender, area, aadhar, password)
        )
        con.commit()
        messagebox.showinfo("Success", "Patient Registered")
    except:
        messagebox.showerror("Error", "Aadhaar already exists")

